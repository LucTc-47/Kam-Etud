# URL publique de l'API Gateway. Le frontend ne doit pas appeler directement
# les ports internes des microservices.
VITE_API_URL=http://localhost:8080

# Pour tester depuis un autre appareil du reseau local, remplacez localhost
# par l'adresse IPv4 de la machine qui execute la Gateway.

# Variables a fournir aux processus backend concernes (ne pas mettre de vrais
# secrets dans ce fichier versionne) :
# JWT_SECRET=<meme-cle-base64-pour-gateway-identity-support>
# INTERNAL_SERVICE_TOKEN=<meme-jeton-long-pour-request-business-payment-support>
# PAYMENT_PROVIDER=mock
# MESOMB_BASE_URL=https://business.mesomb.com/fr/api/v1.1
# MESOMB_APPLICATION_KEY=<secret-local>
# MESOMB_ACCESS_KEY=<secret-local>
# MESOMB_SECRET_KEY=<secret-local>
# MESOMB_REQUEST_TIMEOUT_SECONDS=30
# MESOMB_MAX_NETWORK_RETRIES=0
