# Secret Base64 HMAC commun a identity-service, api-gateway et support-service.
# Remplacer cette valeur en environnement partage; ne jamais committer le vrai secret.
JWT_SECRET=REMPLACER_PAR_UN_SECRET_BASE64_D_AU_MOINS_32_OCTETS

# URL autorisee par la configuration CORS de la Gateway.
FRONTEND_URL=http://localhost:5173
FRONTEND_ALT_URL=http://127.0.0.1:5173
FRONTEND_LAN_PATTERN=http://*:5173

# URLs internes surchargeables lorsque les services ne tournent pas en local.
IDENTITY_SERVICE_URL=http://localhost:8081
REQUEST_SERVICE_URL=http://localhost:8082
CATALOG_SERVICE_URL=http://localhost:8083
BUSINESS_SERVICE_URL=http://localhost:8084
PAYMENT_SERVICE_URL=http://localhost:8085
SUPPORT_SERVICE_URL=http://localhost:8086
SUPPORT_SERVICE_WS_URL=ws://localhost:8086

# Ports PostgreSQL exposes sur l'hote. Ces valeurs sont celles de
# docker-compose.yml : elles evitent la plage 5433-5532 reservee par Windows
# et une installation PostgreSQL locale occupant deja 5432.
# Les conteneurs continuent d'ecouter sur 5432 en interne.
IDENTITY_DB_PORT=5431
CATALOG_DB_PORT=5632
REQUEST_DB_PORT=5633
BUSINESS_DB_PORT=5634
PAYMENT_DB_PORT=5635
SUPPORT_DB_PORT=5636

# Identifiants PostgreSQL utilises par les services lorsque DB_USERNAME/DB_PASSWORD
# ne sont pas surcharges individuellement.
DB_USERNAME=user
DB_PASSWORD=password

# Jeton commun aux appels directs Request -> Business -> Payment/Support.
# Generer une valeur longue et differente en production.
INTERNAL_SERVICE_TOKEN=change-this-internal-token

# Paiement local. Utiliser "mock" pour les tests sans argent reel.
# Utiliser "mesomb" seulement avec de vraies cles configurees hors Git.
# PAYMENT_MODE est un alias equivalent utilise par les fichiers Docker Compose ;
# le service resout payment.provider=${PAYMENT_PROVIDER:${PAYMENT_MODE:mesomb}}.
PAYMENT_PROVIDER=mock

# Secrets du fournisseur de paiement. Ne jamais committer les valeurs reelles.
MESOMB_BASE_URL=https://business.mesomb.com/fr/api/v1.1
MESOMB_APPLICATION_KEY=REMPLACER_EN_LOCAL
MESOMB_ACCESS_KEY=REMPLACER_EN_LOCAL
MESOMB_SECRET_KEY=REMPLACER_EN_LOCAL
MESOMB_REQUEST_TIMEOUT_SECONDS=30
MESOMB_MAX_NETWORK_RETRIES=0

# Auto-validation Business Service.
ORDER_AUTO_VALIDATION_DELAY=PT24H
ORDER_AUTO_VALIDATION_SCAN_MS=60000
ORDER_AUTO_VALIDATION_INITIAL_DELAY_MS=15000

# Stockage Support Service.
STORAGE_LOCATION=storage
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=10MB
