# Copy this file to Backend-Kametude/.env.prod on the VPS.
# Do not commit Backend-Kametude/.env.prod.
# Generate long random values for every password/token before deployment.

# Shared application secrets.
JWT_SECRET=
INTERNAL_SERVICE_TOKEN=

# PostgreSQL credentials.
IDENTITY_DB_USERNAME=
IDENTITY_DB_PASSWORD=

CATALOG_DB_USERNAME=
CATALOG_DB_PASSWORD=

REQUEST_DB_USERNAME=
REQUEST_DB_PASSWORD=

BUSINESS_DB_USERNAME=
BUSINESS_DB_PASSWORD=

PAYMENT_DB_USERNAME=
PAYMENT_DB_PASSWORD=

SUPPORT_DB_USERNAME=
SUPPORT_DB_PASSWORD=

# RabbitMQ internal credentials. RabbitMQ ports are not exposed by prod compose.
RABBITMQ_DEFAULT_USER=
RABBITMQ_DEFAULT_PASS=

# Runtime options.
PAYMENT_MODE=mock
STORAGE_LOCATION=/app/storage
