# Copier ce fichier vers Backend-Kametude/.env.prod sur le VPS.
# .env.prod est ignore par .gitignore et ne doit jamais etre committe.
#
# Generer chaque secret avec une valeur longue et aleatoire :
#   openssl rand -hex 32
#
# Les mots de passe Postgres sont injectes dans du SQL au premier demarrage.
# Eviter les apostrophes et les antislashs par prudence.

# ---------------------------------------------------------------------------
# Exposition publique
# ---------------------------------------------------------------------------

# Domaine public, SANS protocole ni prefixe www.
# Sert a construire la regle Traefik : Host(`kametud.com`) || Host(`www.kametud.com`)
PUBLIC_SITE_HOST=kametud.com

# Interrupteur d'exposition publique.
#
# false : Traefik ignore totalement le conteneur. La stack tourne et reste
#         testable par tunnel SSH, mais aucun certificat n'est demande.
#         A garder tant que l'enregistrement DNS ne pointe pas vers la machine,
#         sinon Let's Encrypt echoue en boucle et pollue le Traefik voisin.
# true  : le site devient public en HTTPS.
#
# Bascule :
#   sed -i 's/^TRAEFIK_ENABLE=.*/TRAEFIK_ENABLE=true/' .env.prod
#   docker compose --env-file .env.prod -f docker-compose.prod.yml up -d frontend
TRAEFIK_ENABLE=false

# Reseau Docker du Traefik deja installe sur la machine. Notre frontend s'y
# raccorde pour etre routable. Declare « external » : un « docker compose down »
# de notre cote ne peut pas le supprimer, donc pas couper les applications
# voisines qui l'utilisent.
# A verifier avec : docker network ls
TRAEFIK_NETWORK=rctt_default

# Port local de diagnostic, publie sur 127.0.0.1 uniquement.
# Le trafic public n'emprunte PAS ce port : Traefik joint le conteneur
# directement par le reseau Docker. Sert a tester en SSH :
#   curl http://127.0.0.1:8090/healthz
# Sur cette machine, 80, 443 et 3000-3999 sont reserves aux autres applications.
PUBLIC_HTTP_PORT=8090

# URL publique complete. Sert d'origine CORS autorisee pour un client qui
# appellerait l'API directement, sans passer par le nginx du frontend.
PUBLIC_SITE_URL=https://kametud.com
PUBLIC_SITE_ALT_URL=https://www.kametud.com

# Tag des images tirees depuis GHCR. « latest » suit la branche principale ;
# mettre un SHA de commit pour figer une version ou revenir en arriere.
IMAGE_TAG=latest

# ---------------------------------------------------------------------------
# Secrets applicatifs partages
# ---------------------------------------------------------------------------

# Doit etre identique pour api-gateway et tous les services.
JWT_SECRET=
# Protege les routes /internal/** que la Gateway n'expose pas.
INTERNAL_SERVICE_TOKEN=

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
# Une seule instance heberge les six bases, pour tenir dans la RAM du VPS.
# Chaque service conserve son role dedie, proprietaire de sa seule base.

# Role d'administration : cree les six bases au premier demarrage, puis inutilise.
POSTGRES_ADMIN_USER=kametud_admin
POSTGRES_ADMIN_PASSWORD=

IDENTITY_DB_USERNAME=identity_user
IDENTITY_DB_PASSWORD=

CATALOG_DB_USERNAME=catalog_user
CATALOG_DB_PASSWORD=

REQUEST_DB_USERNAME=request_user
REQUEST_DB_PASSWORD=

BUSINESS_DB_USERNAME=business_user
BUSINESS_DB_PASSWORD=

PAYMENT_DB_USERNAME=payment_user
PAYMENT_DB_PASSWORD=

SUPPORT_DB_USERNAME=support_user
SUPPORT_DB_PASSWORD=

# ---------------------------------------------------------------------------
# Options d'execution
# ---------------------------------------------------------------------------

PAYMENT_MODE=mock
STORAGE_LOCATION=/app/storage

# Mot de passe des comptes admin@kametud.com et moderator@kametud.com, crees
# automatiquement au demarrage par le service « seed ». Ces deux roles ne
# peuvent pas etre obtenus par le formulaire d'inscription.
#
# Valeur simple pour la demonstration. La plateforme etant publique et
# l'adresse admin@ devinable, a changer des la fin de la presentation.
SEED_ADMIN_PASSWORD=Admin1234!

# ---------------------------------------------------------------------------
# Retire de cette version
# ---------------------------------------------------------------------------
# RABBITMQ_DEFAULT_USER / RABBITMQ_DEFAULT_PASS ne sont plus utilises.
# Aucun pom.xml ne declare spring-boot-starter-amqp et aucun service ne publie
# ni ne consomme de message : le conteneur coutait environ 250 Mo pour rien.
# A retablir le jour ou une communication asynchrone sera reellement branchee.
